{
  "name": "image-compositor",
  "private": true,
  "version": "0.0.0",
  "productName": "Compositor",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:cf": "vite",
    "dev:electron": "node scripts/dev-electron.mjs",
    "dev:vp": "vp dev",
    "build": "tsc -b && vite build",
    "build:electron:main": "tsc -p tsconfig.electron.json",
    "build:electron:app": "npm run build && npm run build:electron:main",
    "build:electron": "npm run build:electron:app && electron-builder --mac dir zip",
    "build:cf": "vite build",
    "deploy:cf": "npm run build && wrangler deploy",
    "preview": "vite preview",
    "preview:cf": "wrangler dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test",
    "pretest:electron": "npm run build:electron:app",
    "test:electron": "playwright test -c playwright.electron.config.ts",
    "pretest:electron:packaged": "npm run build:electron",
    "test:electron:packaged": "playwright test -c playwright.electron-packaged.config.ts",
    "check": "tsc -b && vitest run",
    "lint": "eslint .",
    "perf:budget": "node scripts/check-perf-budget.mjs"
  },
  "build": {
    "appId": "com.imagecompositor.app",
    "productName": "Compositor",
    "icon": "build/icon.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/client/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dir",
        "zip"
      ]
    }
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.4.1",
    "dexie-react-hooks": "^4.4.0",
    "heic2any": "^0.0.4",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "pixi.js": "^8.17.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "utif": "^3.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@cloudflare/workers-types": "^4.20260329.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^8.0.3",
    "vite-plus": "^0.1.14",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
