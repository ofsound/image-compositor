{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "image-compositor",
  "compatibility_date": "2026-03-30",
  "routes": [
    {
      "pattern": "compositor.ofsound.net",
      "zone_name": "ofsound.net",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
  },
  "main": "./src/cloudflare.ts",
}
